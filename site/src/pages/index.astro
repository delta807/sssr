---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="app-container">
    <!-- Header Controls -->
    <div class="controls">
      <div class="view-tabs">
        <button class="view-tab active" data-view="timeline">📊 Timeline</button>
        <button class="view-tab" data-view="characters">👥 Characters</button>
        <button class="view-tab" data-view="deaths">💀 Deaths</button>
        <button class="view-tab" data-view="floors">🏢 Floors</button>
        <button class="view-tab" data-view="network">🕸️ Network</button>
      </div>
      
      <div class="search-box">
        <input type="text" id="search-input" placeholder="Search characters, events, chapters..." />
        <select id="search-filter">
          <option value="all">All</option>
          <option value="characters">Characters</option>
          <option value="events">Events</option>
          <option value="deaths">Deaths</option>
          <option value="skills">Skills</option>
        </select>
      </div>
    </div>

    <!-- Stats Bar -->
    <div class="stats-bar">
      <div class="stat-card">
        <span class="stat-number" id="stat-chapters">0</span>
        <span class="stat-label">Chapters</span>
      </div>
      <div class="stat-card">
        <span class="stat-number" id="stat-characters">0</span>
        <span class="stat-label">Characters</span>
      </div>
      <div class="stat-card">
        <span class="stat-number" id="stat-deaths">0</span>
        <span class="stat-label">Deaths</span>
      </div>
      <div class="stat-card">
        <span class="stat-number" id="stat-loops">0</span>
        <span class="stat-label">Loops</span>
      </div>
      <div class="stat-card">
        <span class="stat-number" id="stat-skills">0</span>
        <span class="stat-label">Skills</span>
      </div>
    </div>

    <!-- Views -->
    <div class="view-container">
      <!-- Timeline View -->
      <div class="view active" id="timeline-view">
        <div class="timeline-header">
          <h2>Multi-Loop Timeline</h2>
          <div class="timeline-legend">
            <span class="legend-item"><span class="dot death"></span> Death</span>
            <span class="legend-item"><span class="dot loop"></span> Loop/Regression</span>
            <span class="legend-item"><span class="dot floor"></span> Floor Change</span>
            <span class="legend-item"><span class="dot skill"></span> New Skill</span>
          </div>
        </div>
        <div class="timeline-wrapper" id="timeline-wrapper">
          <div class="loading">Loading timeline visualization...</div>
        </div>
      </div>

      <!-- Characters View -->
      <div class="view" id="characters-view">
        <div class="view-header">
          <h2>Character Tracker</h2>
          <div class="character-filters">
            <button class="filter-btn active" data-filter="all">All</button>
            <button class="filter-btn" data-filter="alive">🟢 Alive</button>
            <button class="filter-btn" data-filter="dead">🔴 Dead</button>
            <button class="filter-btn" data-filter="frequent">Most Appearances</button>
          </div>
        </div>
        <div class="characters-grid" id="characters-grid">
          <div class="loading">Loading characters...</div>
        </div>
      </div>

      <!-- Deaths View -->
      <div class="view" id="deaths-view">
        <div class="view-header">
          <h2>Death Records</h2>
          <div class="death-stats" id="death-stats"></div>
        </div>
        <div class="deaths-container" id="deaths-container">
          <div class="loading">Loading death records...</div>
        </div>
      </div>

      <!-- Floors View -->
      <div class="view" id="floors-view">
        <div class="view-header">
          <h2>Floor Progression Grid</h2>
          <p class="view-subtitle">Chapters per floor across timeline</p>
        </div>
        <div class="floors-grid" id="floors-grid">
          <div class="loading">Loading floor data...</div>
        </div>
      </div>

      <!-- Network View -->
      <div class="view" id="network-view">
        <div class="view-header">
          <h2>Character Relationship Network</h2>
          <p class="view-subtitle">Node size = appearances, Edge thickness = co-appearances</p>
        </div>
        <div class="network-container" id="network-viz">
          <div class="loading">Loading network graph...</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Detail Modal -->
  <div class="modal" id="detail-modal">
    <div class="modal-content">
      <button class="modal-close">&times;</button>
      <div class="modal-body" id="modal-body"></div>
    </div>
  </div>
</Layout>

<script>
  // ===== DATA STORE =====
  let chapterData = [];
  let loopData = [];
  let characterData = [];
  let deathData = [];
  let allSkills = new Set();

  // ===== VIEW SWITCHING =====
  const viewTabs = document.querySelectorAll('.view-tab');
  const views = document.querySelectorAll('.view');

  viewTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const viewName = tab.dataset.view;
      
      viewTabs.forEach(t => t.classList.remove('active'));
      views.forEach(v => v.classList.remove('active'));
      
      tab.classList.add('active');
      document.getElementById(`${viewName}-view`).classList.add('active');
      
      // Render view
      if (viewName === 'timeline') renderTimeline();
      else if (viewName === 'characters') renderCharacters();
      else if (viewName === 'deaths') renderDeaths();
      else if (viewName === 'floors') renderFloors();
      else if (viewName === 'network') renderNetwork();
    });
  });

  // ===== LOAD DATA =====
  async function loadAllData() {
    try {
      const [chaptersRes, loopsRes, charsRes, deathsRes] = await Promise.all([
        fetch('/sssr/data/all-chapters.json'),
        fetch('/sssr/data/loops.json'),
        fetch('/sssr/data/characters.json'),
        fetch('/sssr/data/deaths.json')
      ]);

      chapterData = await chaptersRes.json();
      loopData = (await loopsRes.json()).loops;
      characterData = (await charsRes.json()).characters;
      deathData = (await deathsRes.json()).deaths;

      // Extract all skills
      chapterData.forEach(ch => {
        ch.annotations?.skills?.forEach(s => allSkills.add(s));
      });

      updateStats();
      renderTimeline();
    } catch (error) {
      console.error('Error loading data:', error);
    }
  }

  function updateStats() {
    const uniqueChars = new Set();
    let deathCount = 0;
    let loopCount = loopData.length;

    chapterData.forEach(ch => {
      ch.annotations?.characters?.forEach(c => uniqueChars.add(c));
      deathCount += ch.annotations?.deaths?.length || 0;
    });

    document.getElementById('stat-chapters').textContent = chapterData.length;
    document.getElementById('stat-characters').textContent = uniqueChars.size;
    document.getElementById('stat-deaths').textContent = deathCount;
    document.getElementById('stat-loops').textContent = loopCount;
    document.getElementById('stat-skills').textContent = allSkills.size;
  }

  // ===== TIMELINE VIEW =====
  function renderTimeline() {
    const container = document.getElementById('timeline-wrapper');
    if (container.dataset.rendered) return;

    // Group chapters by approximate arc/loop
    const arcs = [
      { name: "Prologue", start: 1, end: 10, color: "#4a5568" },
      { name: "Loop 1-5", start: 11, end: 50, color: "#e53e3e" },
      { name: "Loop 6-20", start: 51, end: 100, color: "#dd6b20" },
      { name: "Loop 21-50", start: 101, end: 150, color: "#d69e2e" },
      { name: "Loop 51-100", start: 151, end: 200, color: "#38a169" },
      { name: "Loop 101+", start: 201, end: 250, color: "#3182ce" },
      { name: "Final Arc", start: 251, end: 404, color: "#805ad5" }
    ];

    let html = '<div class="visual-timeline">';
    
    // Timeline axis
    html += '<div class="timeline-axis">';
    for (let i = 0; i <= 40; i++) {
      const ch = i * 10;
      html += `<div class="axis-marker" style="left: ${(i / 40) * 100}%">${ch}</div>`;
    }
    html += '</div>';

    // Arc bars
    arcs.forEach(arc => {
      const left = ((arc.start - 1) / 404) * 100;
      const width = ((arc.end - arc.start + 1) / 404) * 100;
      
      html += `
        <div class="arc-row">
          <div class="arc-label">${arc.name}</div>
          <div class="arc-bar-container">
            <div class="arc-bar" style="left: ${left}%; width: ${width}%; background: ${arc.color}30; border-color: ${arc.color}">
      `;

      // Add chapter markers
      for (let ch = arc.start; ch <= arc.end && ch <= chapterData.length; ch++) {
        const chapter = chapterData[ch - 1];
        if (!chapter) continue;
        
        const chLeft = ((ch - arc.start) / (arc.end - arc.start + 1)) * 100;
        const hasDeath = chapter.annotations?.deaths?.length > 0;
        const hasLoop = chapter.annotations?.loops?.length > 0;
        const hasSkill = chapter.annotations?.skills?.length > 0;
        
        let markerClass = 'ch-marker';
        if (hasDeath) markerClass += ' death';
        if (hasLoop) markerClass += ' loop';
        if (hasSkill) markerClass += ' skill';
        
        html += `
          <div class="${markerClass}" 
               style="left: ${chLeft}%"
               data-chapter="${ch}"
               title="Ch.${ch}: ${chapter.title}">
          </div>
        `;
      }
      
      html += '</div></div></div>';
    });

    // Death timeline
    html += '<div class="death-timeline">';
    html += '<div class="timeline-label">Deaths</div>';
    html += '<div class="death-bar-container">';
    
    chapterData.forEach((ch, idx) => {
      const deaths = ch.annotations?.deaths || [];
      if (deaths.length > 0) {
        const left = (idx / chapterData.length) * 100;
        html += `
          <div class="death-marker" 
               style="left: ${left}%"
               data-chapter="${ch.chapter}"
               title="Ch.${ch.chapter}: ${deaths.map(d => d).join(', ')}">
            <span class="death-count">${deaths.length}</span>
          </div>
        `;
      }
    });
    
    html += '</div></div>';

    // Loop timeline
    html += '<div class="loop-timeline">';
    html += '<div class="timeline-label">Loops</div>';
    html += '<div class="loop-bar-container">';
    
    loopData.slice(0, 20).forEach((loop, idx) => {
      const left = ((loop.startChapter - 1) / 404) * 100;
      const width = Math.max(0.5, ((loop.endChapter - loop.startChapter + 1) / 404) * 100);
      
      html += `
        <div class="loop-segment"
             style="left: ${left}%; width: ${width}%"
             data-loop="${loop.id}"
             title="${loop.name} (Ch.${loop.startChapter}-${loop.endChapter})">
        </div>
      `;
    });
    
    html += '</div></div>';
    html += '</div>';

    container.innerHTML = html;
    container.dataset.rendered = 'true';

    // Add click handlers
    container.querySelectorAll('[data-chapter]').forEach(el => {
      el.addEventListener('click', () => showChapterDetail(el.dataset.chapter));
    });
  }

  // ===== CHARACTERS VIEW =====
  function renderCharacters() {
    const container = document.getElementById('characters-grid');
    if (container.dataset.rendered) return;

    let html = '';
    
    // Sort by appearances
    const sortedChars = [...characterData].sort((a, b) => b.appearances - a.appearances);
    
    sortedChars.forEach(char => {
      const statusClass = char.status === 'alive' ? 'alive' : char.status === 'dead' ? 'dead' : 'unknown';
      const statusEmoji = char.status === 'alive' ? '🟢' : char.status === 'dead' ? '🔴' : '⚪';
      
      html += `
        <div class="character-card" data-character="${char.id}">
          <div class="character-header">
            <h3 class="character-name">${char.name}</h3>
            <span class="character-status ${statusClass}">${statusEmoji} ${char.status}</span>
          </div>
          ${char.aliases?.length ? `<div class="character-aliases">AKA: ${char.aliases.join(', ')}</div>` : ''}
          <div class="character-stats">
            <div class="char-stat">
              <span class="char-stat-num">${char.appearances}</span>
              <span class="char-stat-label">Appearances</span>
            </div>
            <div class="char-stat">
              <span class="char-stat-num">${char.deaths || 0}</span>
              <span class="char-stat-label">Deaths</span>
            </div>
            <div class="char-stat">
              <span class="char-stat-num">${char.firstAppearance}</span>
              <span class="char-stat-label">First Seen</span>
            </div>
          </div>
          ${char.skills?.length ? `
            <div class="character-skills">
              <strong>Skills:</strong> ${char.skills.slice(0, 3).join(', ')}${char.skills.length > 3 ? ` +${char.skills.length - 3} more` : ''}
            </div>
          ` : ''}
        </div>
      `;
    });

    container.innerHTML = html;
    container.dataset.rendered = 'true';

    // Add click handlers
    container.querySelectorAll('.character-card').forEach(card => {
      card.addEventListener('click', () => showCharacterDetail(card.dataset.character));
    });
  }

  // ===== DEATHS VIEW =====
  function renderDeaths() {
    const container = document.getElementById('deaths-container');
    const statsContainer = document.getElementById('death-stats');
    if (container.dataset.rendered) return;

    // Calculate stats
    const byCharacter = {};
    const byType = {};
    
    deathData.forEach(death => {
      byCharacter[death.character] = (byCharacter[death.character] || 0) + 1;
      const type = death.type || 'unknown';
      byType[type] = (byType[type] || 0) + 1;
    });

    // Stats
    statsContainer.innerHTML = `
      <div class="death-stat-card">
        <span class="death-stat-num">${deathData.length}</span>
        <span class="death-stat-label">Total Deaths</span>
      </div>
      <div class="death-stat-card">
        <span class="death-stat-num">${Object.keys(byCharacter).length}</span>
        <span class="death-stat-label">Characters Killed</span>
      </div>
      <div class="death-stat-card">
        <span class="death-stat-num">${byCharacter['Kim Gongja'] || 0}</span>
        <span class="death-stat-label">Kim's Deaths</span>
      </div>
    `;

    // Death log
    let html = '<div class="death-log">';
    
    deathData.forEach((death, idx) => {
      const typeClass = death.type || 'unknown';
      const typeEmoji = typeClass === 'murder' ? '🔪' : typeClass === 'suicide' ? '💔' : typeClass === 'combat' ? '⚔️' : '💀';
      
      html += `
        <div class="death-entry ${typeClass}">
          <div class="death-num">#${idx + 1}</div>
          <div class="death-info">
            <div class="death-header">
              <span class="death-character">${death.character}</span>
              <span class="death-chapter">Ch. ${death.chapter}</span>
              <span class="death-type">${typeEmoji} ${death.type || 'unknown'}</span>
            </div>
            <div class="death-cause">${death.cause}</div>
            ${death.context ? `<div class="death-context">${death.context}</div>` : ''}
          </div>
        </div>
      `;
    });
    
    html += '</div>';
    container.innerHTML = html;
    container.dataset.rendered = 'true';
  }

  // ===== FLOORS VIEW =====
  function renderFloors() {
    const container = document.getElementById('floors-grid');
    if (container.dataset.rendered) return;

    // Approximate floors based on chapter ranges
    const floorMap = new Map();
    
    chapterData.forEach(ch => {
      // Approximate: 5 chapters per floor
      const floor = Math.floor((ch.chapter - 1) / 5) + 1;
      if (!floorMap.has(floor)) {
        floorMap.set(floor, []);
      }
      floorMap.get(floor).push(ch);
    });

    let html = '<div class="floor-grid-viz">';
    html += '<div class="floor-header">';
    html += '<div class="floor-cell">Floor</div>';
    html += '<div class="floor-cell">Chapters</div>';
    html += '<div class="floor-cell">Deaths</div>';
    html += '<div class="floor-cell">Characters</div>';
    html += '<div class="floor-cell">Skills</div>';
    html += '</div>';

    Array.from(floorMap.entries()).forEach(([floor, chapters]) => {
      const deaths = chapters.reduce((sum, ch) => sum + (ch.annotations?.deaths?.length || 0), 0);
      const chars = new Set();
      const skills = new Set();
      
      chapters.forEach(ch => {
        ch.annotations?.characters?.forEach(c => chars.add(c));
        ch.annotations?.skills?.forEach(s => skills.add(s));
      });

      const intensity = Math.min(100, (chapters.length / 5) * 100);
      
      html += `
        <div class="floor-row">
          <div class="floor-cell floor-num">${floor}</div>
          <div class="floor-cell chapter-bar" style="--intensity: ${intensity}%">
            <span class="chapter-count">${chapters.length} ch</span>
            <div class="chapter-range">${chapters[0].chapter}-${chapters[chapters.length - 1].chapter}</div>
          </div>
          <div class="floor-cell">${deaths > 0 ? `💀 ${deaths}` : '—'}</div>
          <div class="floor-cell">${chars.size} chars</div>
          <div class="floor-cell">${skills.size} skills</div>
        </div>
      `;
    });

    html += '</div>';
    container.innerHTML = html;
    container.dataset.rendered = 'true';
  }

  // ===== NETWORK VIEW =====
  function renderNetwork() {
    const container = document.getElementById('network-viz');
    if (container.dataset.rendered) return;

    // Build relationship data
    const nodes = [];
    const links = [];
    const nodeMap = new Map();
    const linkMap = new Map();

    // Create nodes from top characters
    const topChars = characterData.slice(0, 50);
    topChars.forEach((char, i) => {
      nodes.push({
        id: char.id,
        name: char.name,
        group: char.status === 'alive' ? 1 : char.status === 'dead' ? 2 : 3,
        size: Math.sqrt(char.appearances) * 3
      });
      nodeMap.set(char.id, i);
    });

    // Create links from co-appearances
    chapterData.forEach(ch => {
      const chars = ch.annotations?.characters || [];
      for (let i = 0; i < chars.length; i++) {
        for (let j = i + 1; j < chars.length; j++) {
          const id1 = chars[i].toLowerCase().replace(/[^a-z0-9]/g, '-');
          const id2 = chars[j].toLowerCase().replace(/[^a-z0-9]/g, '-');
          
          if (nodeMap.has(id1) && nodeMap.has(id2)) {
            const key = [id1, id2].sort().join('-');
            linkMap.set(key, (linkMap.get(key) || 0) + 1);
          }
        }
      }
    });

    linkMap.forEach((value, key) => {
      const [source, target] = key.split('-');
      links.push({ source, target, value });
    });

    // Simple SVG visualization (no D3 for simplicity)
    const width = container.clientWidth || 800;
    const height = 600;

    // Position nodes in a circle
    const angleStep = (2 * Math.PI) / nodes.length;
    const radius = Math.min(width, height) / 3;
    const centerX = width / 2;
    const centerY = height / 2;

    nodes.forEach((node, i) => {
      const angle = i * angleStep;
      node.x = centerX + radius * Math.cos(angle);
      node.y = centerY + radius * Math.sin(angle);
    });

    let html = `<svg width="${width}" height="${height}" class="network-svg">`;
    
    // Draw links
    links.forEach(link => {
      const source = nodes[nodeMap.get(link.source)];
      const target = nodes[nodeMap.get(link.target)];
      if (source && target) {
        const opacity = Math.min(1, link.value / 10);
        html += `<line x1="${source.x}" y1="${source.y}" x2="${target.x}" y2="${target.y}" 
                       stroke="#4488ff" stroke-opacity="${opacity}" stroke-width="${Math.sqrt(link.value)}" />`;
      }
    });

    // Draw nodes
    nodes.forEach(node => {
      const color = node.group === 1 ? '#44ff88' : node.group === 2 ? '#ff4444' : '#888888';
      html += `
        <circle cx="${node.x}" cy="${node.y}" r="${node.size}" fill="${color}" stroke="#fff" stroke-width="2">
          <title>${node.name} (${node.size} appearances)</title>
        </circle>
        <text x="${node.x}" y="${node.y + node.size + 12}" text-anchor="middle" fill="#e0e0e0" font-size="10">
          ${node.name.length > 10 ? node.name.substring(0, 10) + '...' : node.name}
        </text>
      `;
    });

    html += '</svg>';
    container.innerHTML = html;
    container.dataset.rendered = 'true';
  }

  // ===== MODAL =====
  function showChapterDetail(chapterNum) {
    const chapter = chapterData[ch - 1];
    if (!chapter) return;
    
    const modal = document.getElementById('detail-modal');
    const body = document.getElementById('modal-body');
    
    body.innerHTML = `
      <h2>Chapter ${chapter.chapter}: ${chapter.title}</h2>
      <div class="modal-section">
        <h3>Characters</h3>
        <p>${chapter.annotations?.characters?.join(', ') || 'None'}</p>
      </div>
      <div class="modal-section">
        <h3>Events</h3>
        <ul>${chapter.annotations?.events?.map(e => `<li>${e}</li>`).join('') || '<li>None</li>'}</ul>
      </div>
      ${chapter.annotations?.deaths?.length ? `
        <div class="modal-section">
          <h3>Deaths</h3>
          <ul>${chapter.annotations.deaths.map(d => `<li class="death-text">${d}</li>`).join('')}</ul>
        </div>
      ` : ''}
      ${chapter.annotations?.skills?.length ? `
        <div class="modal-section">
          <h3>Skills</h3>
          <ul>${chapter.annotations.skills.map(s => `<li>${s}</li>`).join('')}</ul>
        </div>
      ` : ''}
    `;
    
    modal.classList.add('active');
  }

  function showCharacterDetail(charId) {
    const char = characterData.find(c => c.id === charId);
    if (!char) return;
    
    const modal = document.getElementById('detail-modal');
    const body = document.getElementById('modal-body');
    
    body.innerHTML = `
      <h2>${char.name}</h2>
      ${char.aliases?.length ? `<p><strong>Aliases:</strong> ${char.aliases.join(', ')}</p>` : ''}
      <p><strong>Status:</strong> ${char.status}</p>
      <p><strong>First Appearance:</strong> Chapter ${char.firstAppearance}</p>
      <p><strong>Total Appearances:</strong> ${char.appearances}</p>
      <p><strong>Deaths:</strong> ${char.deaths || 0}</p>
      ${char.skills?.length ? `<p><strong>Skills:</strong> ${char.skills.join(', ')}</p>` : ''}
    `;
    
    modal.classList.add('active');
  }

  document.querySelector('.modal-close').addEventListener('click', () => {
    document.getElementById('detail-modal').classList.remove('active');
  });

  // ===== SEARCH =====
  document.getElementById('search-input').addEventListener('input', (e) => {
    const query = e.target.value.toLowerCase();
    const filter = document.getElementById('search-filter').value;
    
    if (query.length < 2) return;
    
    // Simple search implementation
    const results = [];
    
    chapterData.forEach(ch => {
      const matches = [];
      
      if (filter === 'all' || filter === 'characters') {
        ch.annotations?.characters?.forEach(c => {
          if (c.toLowerCase().includes(query)) matches.push(`Character: ${c}`);
        });
      }
      
      if (filter === 'all' || filter === 'events') {
        ch.annotations?.events?.forEach(ev => {
          if (ev.toLowerCase().includes(query)) matches.push(`Event: ${ev}`);
        });
      }
      
      if (matches.length > 0) {
        results.push({ chapter: ch.chapter, title: ch.title, matches });
      }
    });
    
    // Show search results in modal
    if (results.length > 0) {
      const modal = document.getElementById('detail-modal');
      const body = document.getElementById('modal-body');
      
      body.innerHTML = `
        <h2>Search Results (${results.length} chapters)</h2>
        ${results.map(r => `
          <div class="search-result">
            <h4>Chapter ${r.chapter}: ${r.title}</h4>
            <ul>${r.matches.map(m => `<li>${m}</li>`).join('')}</ul>
          </div>
        `).join('')}
      `;
      
      modal.classList.add('active');
    }
  });

  // ===== CHARACTER FILTERS =====
  document.querySelectorAll('.character-filters .filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.character-filters .filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      const filter = btn.dataset.filter;
      const cards = document.querySelectorAll('.character-card');
      
      cards.forEach(card => {
        const charId = card.dataset.character;
        const char = characterData.find(c => c.id === charId);
        
        if (filter === 'all') {
          card.style.display = 'block';
        } else if (filter === 'alive' && char?.status === 'alive') {
          card.style.display = 'block';
        } else if (filter === 'dead' && char?.status === 'dead') {
          card.style.display = 'block';
        } else if (filter === 'frequent') {
          card.style.display = char?.appearances > 50 ? 'block' : 'none';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });

  // ===== INIT =====
  document.addEventListener('DOMContentLoaded', loadAllData);
</script>

